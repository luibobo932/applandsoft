APP_ENV=development
APP_NAME=Landsoft Mobile API
API_PREFIX=/api/v1
JWT_SECRET=<CHANGE_ME>
JWT_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:8081

# Chuyen sang false khi da co config mapping va credentials SQL that.
USE_STUB_GATEWAY=true

# Fallback auth cho app mobile neu khong tai hien duoc auth Landsoft.
LOCAL_APP_USERS_FILE=./config/local_app_users.json

# File mapping truy van / stored procedure sau pha discovery.
LANDSOFT_MAPPING_FILE=./config/landsoft_mapping.local.yaml
DISCOVERY_OUTPUT_DIR=./data/discovery
AUDIT_LOG_PATH=./data/audit.log
ANDROID_APK_DOWNLOAD_URL=https://github.com/luibobo932/applandsoft/releases/download/v1.0.0/landsoft-mobile-v1.0.0.apk

# SQL Server Landsoft
# Local Windows tren may nay dang dung `SQL Server`.
# Khi deploy len cloud/container, doi sang `ODBC Driver 18 for SQL Server`.
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_SERVER=
SQL_PORT=1433
SQL_DATABASE=
SQL_USERNAME=
SQL_PASSWORD=
SQL_ENCRYPT=no
SQL_TRUST_SERVER_CERT=yes
